{
  "dxt_version": "0.2",
  "name": "flora-mcp",
  "version": "0.6.0",
  "description": "The official MCP Server for the FLORA API",
  "author": {
    "name": "FLORA"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florafauna-ai/flora-typescript.git"
  },
  "homepage": "https://github.com/florafauna-ai/flora-typescript/tree/main/packages/mcp-server#readme",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "FLORA_API_KEY": "${user_config.FLORA_API_KEY}"
      }
    }
  },
  "user_config": {
    "FLORA_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
